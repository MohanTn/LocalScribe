{
  "name": "local-scribe",
  "productName": "LocalScribe",
  "version": "0.1.2",
  "description": "Local, private speech-to-text powered by whisper.cpp — transcribe files or dictate anywhere with global hotkeys.",
  "main": "./out/main/index.js",
  "author": {
    "name": "LocalScribe Contributors",
    "email": "mohan.tn100@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MohanTn/LocalScribe.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "release:win": "npm run build && electron-builder --win --publish always",
    "release:linux": "npm run build && electron-builder --linux --publish always"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "better-sqlite3": "^11.7.0",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.0",
    "zustand": "^5.0.2"
  }
}
